{
  "name": "gh05tpl/messenger-prometheus-bundle",
  "description": "Symfony bundle exposing Messenger worker metrics for Prometheus.",
  "type": "symfony-bundle",
  "keywords": [
    "symfony",
    "symfony-bundle",
    "messenger",
    "prometheus",
    "metrics",
    "monitoring"
  ],
  "homepage": "https://github.com/Gh05tPL/messenger-prometheus-bundle",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/Gh05tPL/messenger-prometheus-bundle/issues",
    "source": "https://github.com/Gh05tPL/messenger-prometheus-bundle"
  },
  "require": {
    "php": ">=8.2",
    "artprima/prometheus-metrics-bundle": "^1.22",
    "symfony/event-dispatcher": "^5.4 || ^6.4 || ^7.4 || ^8.0",
    "symfony/http-kernel": "^5.4 || ^6.4 || ^7.4 || ^8.0",
    "symfony/messenger": "^5.4 || ^6.4 || ^7.4 || ^8.0",
    "symfony/dependency-injection": "^5.4 || ^6.4 || ^7.4 || ^8.0",
    "symfony/config": "^5.4 || ^6.4 || ^7.4 || ^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Gh05tPL\\MessengerPrometheusBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Gh05tPL\\MessengerPrometheusBundle\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
